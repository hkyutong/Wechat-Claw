{
  "name": "wechat-claw",
  "version": "0.1.0",
  "type": "module",
  "description": "Wechat-Claw by YutoAI: WeChat gateway plugin via Proxy API",
  "license": "MIT",
  "author": "YutoAI",
  "files": [
    "index.ts",
    "src",
    "openclaw.plugin.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YutoAI/Wechat-Claw.git"
  },
  "keywords": [
    "wechat-claw",
    "wechat",
    "微信",
    "gateway",
    "plugin",
    "yutoai"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "wechat",
      "label": "Wechat-Claw",
      "selectionLabel": "Wechat-Claw (微信)",
      "docsPath": "/channels/wechat",
      "docsLabel": "wechat",
      "blurb": "Wechat-Claw by YutoAI. WeChat channel via Proxy API.",
      "order": 80
    },
    "install": {
      "npmSpec": "wechat-claw",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.10.0",
    "openclaw": ">=2026.2.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.9"
  },
  "scripts": {
    "test": "npx tsx test-channel.ts",
    "test:plugin": "npx tsx test-plugin.ts",
    "typecheck": "tsc --noEmit"
  }
}
